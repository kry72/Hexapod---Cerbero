#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

Adafruit_PWMServoDriver driver = Adafruit_PWMServoDriver(0x40, Wire);

#define SDA_PIN 11
#define SCL_PIN 12
#define SERVO_MIN 102
#define SERVO_MAX 512

#define CH_TIBIA  0
#define CH_FEMUR  1
#define CH_COXA   2

// valori calibrati
#define COXA_CENTRO    90
#define COXA_DESTRA    120
#define COXA_SINISTRA  60

#define FEMUR_CENTRO   90
#define FEMUR_GIU      120
#define FEMUR_SU       60

#define TIBIA_CENTRO   90
#define TIBIA_CHIUSA   110
#define TIBIA_APERTA   30

// cicli
#define CICLO0_COXA    90
#define CICLO0_FEMUR   160
#define CICLO0_TIBIA   105

#define CICLO1_FEMUR_CHIUSO  175
#define CICLO1_FEMUR_APERTO  145

int gradiAPWM(int gradi) {
  return map(gradi, 0, 180, SERVO_MIN, SERVO_MAX);
}

void muoviServo(int canale, int gradi) {
  driver.setPWM(canale, 0, gradiAPWM(gradi));
}

void setup() {
  Wire.begin(SDA_PIN, SCL_PIN);
  driver.begin();
  driver.setOscillatorFrequency(27000000);
  driver.setPWMFreq(50);
  delay(500);

  // ciclo 0 - posizione standby
  muoviServo(CH_COXA,  CICLO0_COXA);
  muoviServo(CH_FEMUR, CICLO0_FEMUR);
  muoviServo(CH_TIBIA, CICLO0_TIBIA);
  delay(2000);
}

void loop() {
  // ciclo 0
  muoviServo(CH_COXA,  CICLO0_COXA);
  muoviServo(CH_FEMUR, CICLO0_FEMUR);
  muoviServo(CH_TIBIA, CICLO0_TIBIA);
  delay(2000);

  // ciclo 1 - wake up
  muoviServo(CH_FEMUR, CICLO1_FEMUR_CHIUSO);
  delay(1000);
  muoviServo(CH_FEMUR, CICLO1_FEMUR_APERTO);
  delay(2000);
}
