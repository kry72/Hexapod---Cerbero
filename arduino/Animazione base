#include <Adafruit_NeoPixel.h>
#include <math.h>

#define PIN_EYES      5
#define PIN_RING_BIG  6
#define PIN_LEG_23    7
#define PIN_LEG_01    8
#define PIN_LEG_45    9

#define NUM_EYES      21
#define NUM_RING_BIG  60
#define NUM_LEG       26
#define BRIGHTNESS    70
#define TRAIL         5

Adafruit_NeoPixel eyes(NUM_EYES, PIN_EYES, NEO_GRB + NEO_KHZ800);
Adafruit_NeoPixel ringBig(NUM_RING_BIG, PIN_RING_BIG, NEO_GRB + NEO_KHZ800);
Adafruit_NeoPixel leg01(NUM_LEG, PIN_LEG_01, NEO_GRB + NEO_KHZ800);
Adafruit_NeoPixel leg23(NUM_LEG, PIN_LEG_23, NEO_GRB + NEO_KHZ800);
Adafruit_NeoPixel leg45(NUM_LEG, PIN_LEG_45, NEO_GRB + NEO_KHZ800);

// ===== STATO =====
enum State { BOOT_ROTAZIONE, BOOT_KITT, BOOT_ONDE, IDLE };
State state = BOOT_ROTAZIONE;
unsigned long stateStart = 0;

float phase = 0.0;
int kittPos = 0;
bool kittDir = true;
unsigned long lastKittMove = 0;

// ===== RING GROSSO =====
float ringPos = 0;
unsigned long ringColorTimer = 0;
int ringColorFase = 0;

void animaRingGrosso() {
  unsigned long now = millis();
  if (now - ringColorTimer > 5000) {
    ringColorFase = (ringColorFase + 1) % 3;
    ringColorTimer = now;
  }

  ringPos += 0.5;
  if (ringPos >= NUM_RING_BIG) ringPos = 0;

  uint8_t r, g, b;
  switch (ringColorFase) {
    case 0: r=255; g=255; b=255; break;
    case 1: r=255; g=0;   b=0;   break;
    case 2: r=0;   g=0;   b=255; break;
  }

  ringBig.clear();
  for (int i = 0; i < 20; i++) {
    float fade = pow(1.0 - (i / 20.0), 2);
    int idx = ((int)ringPos + i) % NUM_RING_BIG;
    ringBig.setPixelColor(idx, ringBig.Color(r*fade, g*fade, b*fade));
  }
  ringBig.show();
}

// ===== OCCHIO =====
void animaOcchio() {
  unsigned long t = millis();
  float breath = (sin(t / 1500.0) + 1.0) / 2.0;
  uint8_t extB = 30 + breath * 200;

  int colorFase = (int)(t / 5000.0) % 3;
  uint8_t er, eg, eb;
  switch (colorFase) {
    case 0: er=extB; eg=extB; eb=extB; break;
    case 1: er=extB; eg=0;    eb=0;    break;
    case 2: er=0;    eg=0;    eb=extB; break;
  }
  for (int i = 0; i < 12; i++)
    eyes.setPixelColor(i, eyes.Color(er, eg, eb));

  float wave = fmod(t / 300.0, 8.0);
  for (int i = 0; i < 8; i++) {
    float dist = fabs(i - wave);
    if (dist > 4) dist = 8 - dist;
    float fade = dist < 3 ? 1.0 - (dist / 3.0) : 0;
    uint8_t wb = 180 * fade;
    switch (colorFase) {
      case 0: eyes.setPixelColor(12+i, eyes.Color(0, 0, wb));  break;
      case 1: eyes.setPixelColor(12+i, eyes.Color(0, 0, wb));  break;
      case 2: eyes.setPixelColor(12+i, eyes.Color(wb, 0, 0));  break;
    }
  }

  float beat = fmod(t / 600.0, 1.0);
  uint8_t heartB;
  if (beat < 0.1)       heartB = beat / 0.1 * 255;
  else if (beat < 0.2)  heartB = (0.2 - beat) / 0.1 * 255;
  else if (beat < 0.35) heartB = (beat - 0.2) / 0.15 * 180;
  else if (beat < 0.5)  heartB = (0.5 - beat) / 0.15 * 180;
  else                  heartB = 0;

  switch (colorFase) {
    case 0: eyes.setPixelColor(20, eyes.Color(heartB, heartB, heartB)); break;
    case 1: eyes.setPixelColor(20, eyes.Color(heartB, 0, 0));           break;
    case 2: eyes.setPixelColor(20, eyes.Color(0, 0, heartB));           break;
  }
  eyes.show();
}

// ===== ZAMPE UTILITY =====
void setLeg(int r, int g, int b) {
  for (int i = 0; i < NUM_LEG; i++) {
    leg01.setPixelColor(i, leg01.Color(r, g, b));
    leg23.setPixelColor(i, leg23.Color(r, g, b));
    leg45.setPixelColor(i, leg45.Color(r, g, b));
  }
  leg01.show(); leg23.show(); leg45.show();
}

void drawKitt(int pos, int r, int g, int b) {
  leg01.clear(); leg23.clear(); leg45.clear();
  for (int t = 0; t < TRAIL; t++) {
    int p = pos - t;
    if (p < 0) break;
    float fade = 1.0f - (t / (float)TRAIL);
    leg01.setPixelColor(p, leg01.Color(r*fade, g*fade, b*fade));
    leg23.setPixelColor(p, leg23.Color(r*fade, g*fade, b*fade));
    leg45.setPixelColor(p, leg45.Color(r*fade, g*fade, b*fade));
  }
  leg01.show(); leg23.show(); leg45.show();
}

void drawOnde(float ph) {
  for (int i = 0; i < NUM_LEG; i++) {
    float wave  = sin(i * 0.25 + ph);
    int blue    = (wave + 1.0) * 120;
    int cyan    = (sin(i * 0.18 + ph * 1.4) + 1.0) * 80;
    int violet  = (sin(i * 0.30 - ph * 0.9) + 1.0) * 60;
    leg01.setPixelColor(i, leg01.Color(constrain(violet,0,255), constrain(cyan,0,255), constrain(blue,0,255)));
    leg23.setPixelColor(i, leg23.Color(constrain(violet,0,255), constrain(cyan,0,255), constrain(blue,0,255)));
    leg45.setPixelColor(i, leg45.Color(constrain(violet,0,255), constrain(cyan,0,255), constrain(blue,0,255)));
  }
  leg01.show(); leg23.show(); leg45.show();
}

void setup() {
  eyes.begin();    eyes.setBrightness(80);      eyes.show();
  ringBig.begin(); ringBig.setBrightness(70);   ringBig.show();
  leg01.begin();   leg01.setBrightness(BRIGHTNESS); leg01.show();
  leg23.begin();   leg23.setBrightness(BRIGHTNESS); leg23.show();
  leg45.begin();   leg45.setBrightness(BRIGHTNESS); leg45.show();

  stateStart = millis();
  ringColorTimer = millis();
  lastKittMove = millis();
}

void loop() {
  unsigned long now     = millis();
  unsigned long elapsed = now - stateStart;

  animaRingGrosso();
  animaOcchio();

  switch (state) {

    case BOOT_ROTAZIONE: {
      unsigned long cycleDuration;
      int r, g, b;

      if (elapsed < 5000) {
        cycleDuration = 2000; r=0;   g=200; b=255;
      } else if (elapsed < 10000) {
        cycleDuration = 800;  r=0;   g=255; b=50;
      } else {
        cycleDuration = 300;  r=180; g=0;   b=255;
      }

      float pos  = (float)(elapsed % cycleDuration) / (float)cycleDuration * 3.0f;
      int   cur  = (int)pos % 3;
      int   next = (cur + 1) % 3;
      float tt   = pos - (int)pos;

      float briCur  = (cos(tt * 3.14159f) + 1.0f) * 0.5f;
      float briNext = 1.0f - briCur;

      int colR[3] = {0,0,0}, colG[3] = {0,0,0}, colB[3] = {0,0,0};
      colR[cur]  = r*briCur;  colG[cur]  = g*briCur;  colB[cur]  = b*briCur;
      colR[next] = r*briNext; colG[next] = g*briNext; colB[next] = b*briNext;

      for (int i = 0; i < NUM_LEG; i++) {
        leg01.setPixelColor(i, leg01.Color(colR[0], colG[0], colB[0]));
        leg23.setPixelColor(i, leg23.Color(colR[1], colG[1], colB[1]));
        leg45.setPixelColor(i, leg45.Color(colR[2], colG[2], colB[2]));
      }
      leg01.show(); leg23.show(); leg45.show();
      delay(20);

      if (elapsed >= 15000) {
        state = BOOT_KITT;
        stateStart = now;
        kittPos = 0; kittDir = true;
      }
      break;
    }

    case BOOT_KITT: {
      int speed = constrain((int)(80 - elapsed * 0.004f), 25, 80);

      if (now - lastKittMove > (unsigned long)speed) {
        lastKittMove = now;

        int r, g, b;
        if (elapsed < 4000)       { r=255; g=0;   b=0;   }
        else if (elapsed < 8000)  { r=0;   g=200; b=255; }
        else if (elapsed < 12000) { r=0;   g=255; b=50;  }
        else                      { r=180; g=0;   b=255; }

        drawKitt(kittPos, r, g, b);

        if (kittDir) {
          kittPos++;
          if (kittPos >= NUM_LEG - 1) kittDir = false;
        } else {
          kittPos--;
          if (kittPos <= 0) kittDir = true;
        }
      }

      if (elapsed >= 16000) {
        state = BOOT_ONDE;
        stateStart = now;
        phase = 0;
      }
      break;
    }

    case BOOT_ONDE: {
      drawOnde(phase);
      phase += 0.15;
      delay(35);

      if (elapsed >= 7000) {
        for (int step = 0; step <= 60; step++) {
          float f  = step / 60.0f;
          int   bb = constrain((int)(180 * f), 0, 255);
          int   gg = constrain((int)(20  * f), 0, 255);
          setLeg(0, gg, bb);
          delay(15);
        }
        state = IDLE;
        stateStart = now;
      }
      break;
    }

    case IDLE: {
      setLeg(0, 20, 180);
      delay(35);
      break;
    }
  }
}
