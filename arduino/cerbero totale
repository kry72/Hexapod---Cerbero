// ===== BOOT ANIMATIONS =====
void animRing(uint8_t r, uint8_t g, uint8_t b, float speed=0.6) {
  ringPos += speed;
  if (ringPos >= NUM_RING_BIG) ringPos = 0;
  ringBig.clear();
  for (int i = 0; i < 22; i++) {
    float fade = pow(1.0-(i/22.0),2);
    int idx = ((int)ringPos+i)%NUM_RING_BIG;
    ringBig.setPixelColor(idx, ringBig.Color(r*fade,g*fade,b*fade));
  }
}

void animZampeRotazione(uint32_t t) {
  unsigned long elapsed = t-statoTimer;
  unsigned long cycleDuration;
  uint8_t r,g,b;
  if (elapsed < 5000)       { cycleDuration=2000; r=0;   g=200; b=255; }
  else if (elapsed < 10000) { cycleDuration=800;  r=0;   g=255; b=50;  }
  else                      { cycleDuration=300;  r=180; g=0;   b=255; }

  float pos  = (float)(elapsed%cycleDuration)/(float)cycleDuration*3.0f;
  int   cur  = (int)pos%3, next=(cur+1)%3;
  float tt   = pos-(int)pos;
  float briCur  = (cos(tt*3.14159f)+1.0f)*0.5f;
  float briNext = 1.0f-briCur;
  int colR[3]={0,0,0},colG[3]={0,0,0},colB[3]={0,0,0};
  colR[cur]=r*briCur;   colG[cur]=g*briCur;   colB[cur]=b*briCur;
  colR[next]=r*briNext; colG[next]=g*briNext; colB[next]=b*briNext;

  for (int i = 0; i < NUM_LEG; i++) {
    leg01.setPixelColor(i, leg01.Color(colR[0],colG[0],colB[0]));
    leg23.setPixelColor(i, leg23.Color(colR[1],colG[1],colB[1]));
    leg45.setPixelColor(i, leg45.Color(colR[2],colG[2],colB[2]));
  }
}

void animZampeKitt(uint32_t t) {
  unsigned long elapsed = t-statoTimer;
  int speed = constrain((int)(80-elapsed*0.004f),20,80);
  if (millis()-lastKittMove > (unsigned long)speed) {
    lastKittMove = millis();
    uint8_t r,g,b;
    if (elapsed < 4000)       { r=255; g=0;   b=0;   }
    else if (elapsed < 8000)  { r=0;   g=200; b=255; }
    else if (elapsed < 12000) { r=0;   g=255; b=50;  }
    else                      { r=180; g=0;   b=255; }
    leg01.clear(); leg23.clear(); leg45.clear();
    for (int i = 0; i < 8; i++) {
      int idx = kittPos+i;
      if (idx >= 0 && idx < NUM_LEG) {
        float fade = pow(1.0-(i/8.0),2);
        leg01.setPixelColor(idx, leg01.Color(r*fade,g*fade,b*fade));
        leg23.setPixelColor(idx, leg23.Color(r*fade,g*fade,b*fade));
        leg45.setPixelColor(idx, leg45.Color(r*fade,g*fade,b*fade));
      }
    }
    if (kittDir) { kittPos++; if (kittPos>=NUM_LEG-8) kittDir=false; }
    else         { kittPos--; if (kittPos<=0) kittDir=true; }
  }
}

void animZampeWave(uint32_t t) {
  for (int i = 0; i < NUM_LEG; i++) {
    float wave  = sin(i*0.25+t/500.0);
    int blue    = (wave+1.0)*120;
    int cyan    = (sin(i*0.18+t/400.0)+1.0)*80;
    int violet  = (sin(i*0.30-t/600.0)+1.0)*60;
    leg01.setPixelColor(i, leg01.Color(constrain(violet,0,255),constrain(cyan,0,255),constrain(blue,0,255)));
    leg23.setPixelColor(i, leg23.Color(constrain(violet,0,255),constrain(cyan,0,255),constrain(blue,0,255)));
    leg45.setPixelColor(i, leg45.Color(constrain(violet,0,255),constrain(cyan,0,255),constrain(blue,0,255)));
  }
}

void setZampeBlu() {
  for (int i = 0; i < NUM_LEG; i++) {
    leg01.setPixelColor(i, leg01.Color(0,20,180));
    leg23.setPixelColor(i, leg23.Color(0,20,180));
    leg45.setPixelColor(i, leg45.Color(0,20,180));
  }
}

void animOcchio(uint32_t t, bool show8, bool showCentrale, float centraleFade) {
  for (int i = 0; i < 12; i++) {
    float wave = (sin(i*0.5+t/600.0)+1.0)/2.0;
    uint8_t b = 80+wave*140, w = wave*60;
    eyes.setPixelColor(i, eyes.Color(w,w,b));
  }
  if (show8) {
    eyePos8 += 0.25;
    if (eyePos8 >= 8) eyePos8 = 0;
    for (int i = 0; i < 8; i++) eyes.setPixelColor(12+i,0);
    for (int i = 0; i < 5; i++) {
      float fade = pow(1.0-(i/5.0),2);
      int idx = 12+((int)(eyePos8+i)%8);
      eyes.setPixelColor(idx, eyes.Color(255*fade,80*fade,0));
    }
  } else {
    for (int i = 12; i < 20; i++) eyes.setPixelColor(i,0);
  }
  if (showCentrale) {
    uint8_t cp = 200*centraleFade;
    eyes.setPixelColor(20, eyes.Color(cp,cp,cp));
  } else {
    eyes.setPixelColor(20,0);
  }
}

void setOcchioBlu() {
  for (int i = 0; i < 12; i++) eyes.setPixelColor(i, eyes.Color(0,20,180));
  for (int i = 12; i < 20; i++) eyes.setPixelColor(i, eyes.Color(0,20,180));
  eyes.setPixelColor(20, eyes.Color(220,220,220));
}

// ===== WEBAPP ANIMAZIONI =====
static float legsPhase=0, ringPosWA=0;
static unsigned long ringColorTimer=0;
static int ringColorFase=0, kittPosWA=0;
static bool kittDirWA=true;
static unsigned long lastKittMoveWA=0;

void runWebappAnimations(uint32_t t) {

  // modalità operative
  if (currentMode == "alert") {
    float pulse = (sin(t/200.0)+1.0)/2.0;
    uint8_t r = 100+pulse*155;
    for (int i = 0; i < NUM_LEG; i++) {
      leg01.setPixelColor(i, leg01.Color(r,0,0));
      leg23.setPixelColor(i, leg23.Color(r,0,0));
      leg45.setPixelColor(i, leg45.Color(r,0,0));
    }
    for (int i = 0; i < NUM_RING_BIG; i++) ringBig.setPixelColor(i, ringBig.Color(r,0,0));
    for (int i = 0; i < NUM_EYES; i++) eyes.setPixelColor(i, eyes.Color(r,0,0));
    leg01.show(); leg23.show(); leg45.show(); ringBig.show(); eyes.show();
    return;
  }

  if (currentMode == "stealth") {
    for (int i = 0; i < NUM_LEG; i++) {
      leg01.setPixelColor(i, leg01.Color(0,0,20));
      leg23.setPixelColor(i, leg23.Color(0,0,20));
      leg45.setPixelColor(i, leg45.Color(0,0,20));
    }
    ringBig.clear();
    float breath = (sin(t/2000.0)+1.0)/2.0;
    uint8_t b = 10+breath*30;
    for (int i = 0; i < NUM_EYES; i++) eyes.setPixelColor(i, eyes.Color(0,0,b));
    leg01.show(); leg23.show(); leg45.show(); ringBig.show(); eyes.show();
    return;
  }

  if (currentMode == "core") {
    float breath = (sin(t/2000.0)+1.0)/2.0;
    uint8_t b = 30+breath*80;
    for (int i = 0; i < NUM_LEG; i++) {
      leg01.setPixelColor(i, leg01.Color(0,5,b));
      leg23.setPixelColor(i, leg23.Color(0,5,b));
      leg45.setPixelColor(i, leg45.Color(0,5,b));
    }
    animRing(0,0,255,0.2);
    for (int i = 0; i < NUM_EYES; i++) eyes.setPixelColor(i, eyes.Color(0,5,b));
    leg01.show(); leg23.show(); leg45.show(); ringBig.show(); eyes.show();
    return;
  }

  // modalità normale — controllo webapp
  if (!legsOn || !masterOn) {
    leg01.clear(); leg23.clear(); leg45.clear();
  } else if (legsAnim == "rotazione") {
    legsPhase += 0.25;
    if (legsPhase >= NUM_LEG) legsPhase = 0;
    for (int i = 0; i < NUM_LEG; i++) {
      float dist = fabs(i-legsPhase);
      if (dist > NUM_LEG/2) dist = NUM_LEG-dist;
      float fade = dist < 8 ? pow(1.0-(dist/8.0),2) : 0;
      leg01.setPixelColor(i, leg01.Color(legsR*fade,legsG*fade,legsB*fade));
      leg23.setPixelColor(i, leg23.Color(legsR*fade,legsG*fade,legsB*fade));
      leg45.setPixelColor(i, leg45.Color(legsR*fade,legsG*fade,legsB*fade));
    }
  } else if (legsAnim == "kitt") {
    if (millis()-lastKittMoveWA > 30) {
      lastKittMoveWA = millis();
      leg01.clear(); leg23.clear(); leg45.clear();
      for (int i = 0; i < 10; i++) {
        int idx = kittPosWA+i;
        if (idx >= 0 && idx < NUM_LEG) {
          float fade = pow(1.0-(i/10.0),2);
          leg01.setPixelColor(idx, leg01.Color(legsR*fade,legsG*fade,legsB*fade));
          leg23.setPixelColor(idx, leg23.Color(legsR*fade,legsG*fade,legsB*fade));
          leg45.setPixelColor(idx, leg45.Color(legsR*fade,legsG*fade,legsB*fade));
        }
      }
      if (kittDirWA) { kittPosWA++; if (kittPosWA>=NUM_LEG-10) kittDirWA=false; }
      else           { kittPosWA--; if (kittPosWA<=0) kittDirWA=true; }
    }
  } else if (legsAnim == "wave") {
    for (int i = 0; i < NUM_LEG; i++) {
      float wave = (sin(i*0.4+t/400.0)+1.0)/2.0;
      uint8_t bright = 80+wave*175;
      leg01.setPixelColor(i, leg01.Color(legsR*bright/255,legsG*bright/255,legsB*bright/255));
      leg23.setPixelColor(i, leg23.Color(legsR*bright/255,legsG*bright/255,legsB*bright/255));
      leg45.setPixelColor(i, leg45.Color(legsR*bright/255,legsG*bright/255,legsB*bright/255));
    }
  } else {
    float breath = (sin(t/1500.0)+1.0)/2.0;
    uint8_t b = 60+breath*150;
    for (int i = 0; i < NUM_LEG; i++) {
      leg01.setPixelColor(i, leg01.Color(0,0,b));
      leg23.setPixelColor(i, leg23.Color(0,0,b));
      leg45.setPixelColor(i, leg45.Color(0,0,b));
    }
  }

  if (!ringBigOn || !masterOn) {
    ringBig.clear();
  } else {
    if (millis()-ringColorTimer > 5000) { ringColorFase=(ringColorFase+1)%3; ringColorTimer=millis(); }
    ringPosWA += 0.5;
    if (ringPosWA >= NUM_RING_BIG) ringPosWA = 0;
    uint8_t r,g,b;
    switch (ringColorFase) {
      case 0: r=ringR; g=ringG; b=ringB; break;
      case 1: r=255;   g=0;     b=0;     break;
      case 2: r=0;     g=0;     b=255;   break;
    }
    ringBig.clear();
    for (int i = 0; i < 20; i++) {
      float fade = pow(1.0-(i/20.0),2);
      int idx = ((int)ringPosWA+i)%NUM_RING_BIG;
      ringBig.setPixelColor(idx, ringBig.Color(r*fade,g*fade,b*fade));
    }
  }

  if (!eyesOn || !masterOn) {
    eyes.clear();
  } else {
    float breath = (sin(t/1500.0)+1.0)/2.0;
    if (eyesAnim == "respiro") {
      uint8_t b = 30+breath*200;
      for (int i = 0; i < 12; i++) eyes.setPixelColor(i, eyes.Color(0,0,b));
      uint8_t b2 = 20+breath*150;
      for (int i = 12; i < 20; i++) eyes.setPixelColor(i, eyes.Color(0,b2/3,b2));
      uint8_t bc = 80+breath*175;
      eyes.setPixelColor(20, eyes.Color(bc/4,bc/4,bc));
    } else if (eyesAnim == "pulsar") {
      float pulse = pow((sin(t/400.0)+1.0)/2.0,3);
      uint8_t p = pulse*255;
      for (int i = 0; i < 12; i++) eyes.setPixelColor(i, eyes.Color(p/4,p/4,p));
      for (int i = 12; i < 20; i++) eyes.setPixelColor(i, eyes.Color(0,p/3,p));
      eyes.setPixelColor(20, eyes.Color(p,p,p));
    } else {
      uint8_t o = 150+breath*105;
      for (int i = 0; i < 12; i++) eyes.setPixelColor(i, eyes.Color(o,o/3,0));
      for (int i = 12; i < 20; i++) eyes.setPixelColor(i, eyes.Color(o/2,o/6,0));
      eyes.setPixelColor(20, eyes.Color(255,180,0));
    }
  }

  leg01.show(); leg23.show(); leg45.show();
  ringBig.show(); eyes.show();
}

// ===== SETUP =====
void setup() {
  Serial.begin(115200);

  Wire.begin(SDA_PIN, SCL_PIN);
  driver0.begin(); driver0.setOscillatorFrequency(27000000); driver0.setPWMFreq(50);
  driver1.begin(); driver1.setOscillatorFrequency(27000000); driver1.setPWMFreq(50);

  eyes.begin();    eyes.setBrightness(80);    eyes.show();
  ringBig.begin(); ringBig.setBrightness(70); ringBig.show();
  leg01.begin();   leg01.setBrightness(70);   leg01.show();
  leg23.begin();   leg23.setBrightness(70);   leg23.show();
  leg45.begin();   leg45.setBrightness(70);   leg45.show();

  calibs[0].coxaCentro=90; calibs[0].femurCentro=90; calibs[0].tibiaCentro=90;
  calibs[0].ciclo0Femur=160; calibs[0].ciclo0Tibia=105;
  calibs[0].ciclo1FemurC=175; calibs[0].ciclo1FemurA=145;

  setupWiFi();
  statoTimer = millis();
  ringColorTimer = millis();
}

// ===== LOOP =====
void loop() {
  uint32_t t = millis();
  unsigned long elapsed = t - statoTimer;

  ws.cleanupClients();

  if (stato == RUNNING) {
    runWebappAnimations(t);
    delay(18);
    return;
  }

  switch (stato) {
    case BOOT_RING_BIANCO:
      animRing(255,255,255);
      leg01.clear(); leg23.clear(); leg45.clear(); eyes.clear();
      if (elapsed >= 6000) { stato=BOOT_RING_ROSSO; statoTimer=t; ringPos=0; }
      break;
    case BOOT_RING_ROSSO:
      animRing(255,0,0);
      leg01.clear(); leg23.clear(); leg45.clear(); eyes.clear();
      if (elapsed >= 6000) { stato=BOOT_RING_ARANCIONE; statoTimer=t; ringPos=0; }
      break;
    case BOOT_RING_ARANCIONE:
      animRing(255,80,0);
      leg01.clear(); leg23.clear(); leg45.clear(); eyes.clear();
      if (elapsed >= 6000) { stato=BOOT_RING_BLU; statoTimer=t; ringPos=0; }
      break;
    case BOOT_RING_BLU:
      animRing(0,0,255);
      leg01.clear(); leg23.clear(); leg45.clear(); eyes.clear();
      if (elapsed >= 6000) { stato=BOOT_ZAMPE_ROTAZIONE; statoTimer=t; }
      break;
    case BOOT_ZAMPE_ROTAZIONE:
      animRing(0,0,255,0.3);
      animZampeRotazione(t);
      eyes.clear();
      if (elapsed >= 15000) { stato=BOOT_ZAMPE_KITT; statoTimer=t; kittPos=0; kittDir=true; }
      break;
    case BOOT_ZAMPE_KITT:
      animRing(0,0,255,0.3);
      animZampeKitt(t);
      animOcchio(t, elapsed>8000, elapsed>12000, constrain((elapsed-12000)/2000.0f,0.0f,1.0f));
      if (elapsed >= 16000) { stato=BOOT_ZAMPE_WAVE; statoTimer=t; }
      break;
    case BOOT_ZAMPE_WAVE:
      animRing(0,0,255,0.3);
      animZampeWave(t);
      animOcchio(t,true,true,1.0f);
      if (elapsed >= 7000) { stato=BOOT_ZAMPE_IDLE; statoTimer=t; }
      break;
    case BOOT_ZAMPE_IDLE: {
      animRing(0,0,255,0.3);
      float progress = constrain(elapsed/2000.0f,0.0f,1.0f);
      uint8_t b=180*progress, g=20*progress;
      for (int i = 0; i < NUM_LEG; i++) {
        leg01.setPixelColor(i, leg01.Color(0,g,b));
        leg23.setPixelColor(i, leg23.Color(0,g,b));
        leg45.setPixelColor(i, leg45.Color(0,g,b));
      }
      animOcchio(t,true,true,1.0f);
      if (elapsed >= 3000) { stato=BOOT_FINALE; statoTimer=t; }
      break;
    }
    case BOOT_FINALE:
      animRing(0,0,255,0.3);
      setZampeBlu();
      setOcchioBlu();
      if (elapsed >= 2000) { stato=RUNNING; ringColorTimer=millis(); }
      break;
    default: break;
  }

  ringBig.show();
  leg01.show(); leg23.show(); leg45.show();
  eyes.show();
  delay(18);
}
